        "height": 8,
        "widget": {
          "title": "Memory Usage % (prod)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum(redis_server_used_memory{db=\"11641044\"}) / max(db_memory_limit_bytes{db=\"11641044\"}) * 100"
                },
                "plotType": "LINE",
                "legendTemplate": "usage %"
              }
            ],
            "yAxis": {
              "label": "%"
            },
            "thresholds": [
              {
                "value": 80
              },
              {
                "value": 90
              }
            ]
          }
        }
      },
      {
        "yPos": 52,
        "xPos": 8,
