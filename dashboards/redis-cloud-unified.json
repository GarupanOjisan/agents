              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum(rate(endpoint_other_requests_total{db=\"14142587\"}[5m]))"
                },
                "plotType": "LINE",
                "legendTemplate": "other"
              }
            ],
            "yAxis": {
              "label": "ops/sec"
            }
          }
        }
      },
      {
        "yPos": 34,
        "width": 12,
        "height": 8,
        "widget": {
          "title": "Connected Clients",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (db_name) (redis_server_connected_clients{db=\"11641044\", role=\"master\"})"
                },
                "plotType": "LINE",
                "legendTemplate": "{{db_name}}"
              },
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (db_name) (redis_server_connected_clients{db=\"14142587\", role=\"master\"})"
                },
                "plotType": "LINE",
                "legendTemplate": "{{db_name}}"
              }
            ],
            "yAxis": {
              "label": "clients"
            }
          }
        }
      },
      {
        "yPos": 34,
        "xPos": 12,
        "width": 12,
        "height": 8,
        "widget": {
          "title": "Connection & Dispatch Errors",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum(rate(endpoint_client_establishment_failures_total[5m]))"
                },
                "plotType": "LINE",
                "legendTemplate": "establishment failures"
              },
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum(rate(endpoint_dispatch_failures_total[5m]))"
                },
                "plotType": "LINE",
                "legendTemplate": "dispatch failures"
              }
            ],
            "yAxis": {
              "label": "errors/sec"
            }
          }
        }
      },
      {
        "yPos": 42,
        "width": 24,
        "height": 8,
        "widget": {
          "title": "Node Ops/sec (400k limit per node)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum by (node, exported_cluster) (rate(endpoint_read_requests_total[5m]) + rate(endpoint_write_requests_total[5m]) + rate(endpoint_other_requests_total[5m]))"
                },
                "plotType": "LINE",
                "legendTemplate": "node-{{node}}"
              }
            ],
            "yAxis": {
              "label": "ops/sec"
            },
            "thresholds": [
              {
                "value": 400000
              }
            ]
          }
        }
      },
      {
        "yPos": 50,
        "width": 24,
        "height": 2,
        "widget": {
