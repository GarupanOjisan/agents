{
  "displayName": "Redis Cloud - Unified Dashboard",
  "labels": {
    "redis": ""
  },
  "mosaicLayout": {
    "columns": 24,
    "tiles": [
      {
        "width": 24,
        "height": 2,
        "widget": {
          "title": "Section 1: Health Summary",
          "text": {
            "content": "",
            "format": "RAW"
          }
        }
      },
      {
        "yPos": 2,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "prod DB Status",
          "scorecard": {
            "timeSeriesQuery": {
              "prometheusQuery": "db_status{db=\"11641044\"}"
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_LINE"
            },
            "thresholds": [
              {
                "value": 1,
                "color": "RED",
                "direction": "ABOVE"
              }
            ]
          }
        }
      },
      {
        "yPos": 2,
        "xPos": 4,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "prod-cluster DB Status",
          "scorecard": {
            "timeSeriesQuery": {
              "prometheusQuery": "db_status{db=\"14142587\"}"
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_LINE"
            },
            "thresholds": [
              {
                "value": 1,
                "color": "RED",
                "direction": "ABOVE"
              }
            ]
          }
        }
      },
      {
        "yPos": 2,
        "xPos": 8,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Cluster Quorum",
          "scorecard": {
            "timeSeriesQuery": {
              "prometheusQuery": "min(has_quorum)"
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_LINE"
            },
            "thresholds": [
              {
                "value": 1,
                "color": "RED",
                "direction": "BELOW"
              }
            ]
          }
        }
      },
      {
        "yPos": 2,
        "xPos": 12,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Live Nodes",
          "scorecard": {
            "timeSeriesQuery": {
              "prometheusQuery": "sum(total_live_nodes_count) / sum(total_nodes_count)"
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_LINE"
            },
            "thresholds": [
              {
                "value": 1,
                "color": "RED",
                "direction": "BELOW"
              }
            ]
          }
        }
      },
      {
        "yPos": 2,
        "xPos": 16,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Dispatch Failures (5m)",
          "scorecard": {
            "timeSeriesQuery": {
              "prometheusQuery": "sum(increase(endpoint_dispatch_failures_total[5m]))"
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_LINE"
            },
            "thresholds": [
              {
                "value": 1,
                "color": "RED",
                "direction": "ABOVE"
              }
            ]
          }
        }
      },
      {
        "yPos": 2,
        "xPos": 20,
        "width": 4,
        "height": 4,
        "widget": {
          "title": "Conn Errors (5m)",
          "scorecard": {
            "timeSeriesQuery": {
              "prometheusQuery": "sum(increase(endpoint_client_establishment_failures_total[5m]))"
            },
            "sparkChartView": {
              "sparkChartType": "SPARK_LINE"
            },
            "thresholds": [
              {
                "value": 1,
                "color": "RED",
                "direction": "ABOVE"
              }
            ]
          }
        }
      },
      {
        "yPos": 6,
        "width": 24,
        "height": 2,
        "widget": {
          "title": "Section 2: Latency (prod | prod-cluster)",
          "text": {
            "content": "",
            "format": "RAW"
          }
        }
      },
      {
        "yPos": 8,
        "width": 12,
        "height": 8,
        "widget": {
          "title": "Read Latency (prod) - p50 / p99",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "histogram_quantile(0.5, sum by (le) (rate(endpoint_read_requests_latency_histogram_bucket{db=\"11641044\"}[5m])))"
                },
                "plotType": "LINE",
                "legendTemplate": "p50"
              },
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "histogram_quantile(0.99, sum by (le) (rate(endpoint_read_requests_latency_histogram_bucket{db=\"11641044\"}[5m])))"
                },
                "plotType": "LINE",
                "legendTemplate": "p99"
              }
            ],
            "yAxis": {
              "label": "Latency (us)"
            }
          }
        }
      },
      {
        "yPos": 8,
        "xPos": 12,
        "width": 12,
        "height": 8,
        "widget": {
          "title": "Read Latency (prod-cluster) - p50 / p99",
