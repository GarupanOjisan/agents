      {
        "yPos": 16,
        "xPos": 12,
        "width": 12,
        "height": 8,
        "widget": {
          "title": "Write Latency (prod-cluster) - p50 / p99",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "histogram_quantile(0.5, sum by (le) (rate(endpoint_write_requests_latency_histogram_bucket{db=\"14142587\"}[5m])))"
                },
                "plotType": "LINE",
                "legendTemplate": "p50"
              },
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "histogram_quantile(0.99, sum by (le) (rate(endpoint_write_requests_latency_histogram_bucket{db=\"14142587\"}[5m])))"
