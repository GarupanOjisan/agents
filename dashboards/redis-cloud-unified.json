                "plotType": "LINE",
                "legendTemplate": "write"
              },
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum(rate(endpoint_other_requests_total{db=\"11641044\"}[5m]))"
                },
                "plotType": "LINE",
                "legendTemplate": "other"
              }
            ],
            "yAxis": {
              "label": "ops/sec"
            }
          }
        }
      },
      {
        "yPos": 26,
        "xPos": 12,
        "width": 12,
        "height": 8,
        "widget": {
          "title": "Ops/sec (prod-cluster)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum(rate(endpoint_read_requests_total{db=\"14142587\"}[5m]))"
                },
                "plotType": "LINE",
                "legendTemplate": "read"
              },
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum(rate(endpoint_write_requests_total{db=\"14142587\"}[5m]))"
