        "height": 2,
        "widget": {
          "title": "Section 3: Throughput & Connections",
          "text": {
            "content": "",
            "format": "RAW"
          }
        }
      },
      {
        "yPos": 26,
        "width": 12,
        "height": 8,
        "widget": {
          "title": "Ops/sec (prod)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum(rate(endpoint_read_requests_total{db=\"11641044\"}[5m]))"
                },
                "plotType": "LINE",
                "legendTemplate": "read"
              },
              {
                "timeSeriesQuery": {
                  "prometheusQuery": "sum(rate(endpoint_write_requests_total{db=\"11641044\"}[5m]))"
